# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot in private chat
# Get your ID via @userinfobot
TELEGRAM_ALLOWED_USER_IDS=123456789

# ── Claude / Anthropic ────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# Model to use (claude-opus-4-6 recommended for personal assistant)
CLAUDE_MODEL=claude-opus-4-6

# Max tokens per response
CLAUDE_MAX_TOKENS=2048

# How many messages to keep in memory per user (user+assistant pairs)
CLAUDE_HISTORY_LIMIT=20

# System prompt for personal chat (optional — has sensible default)
# CLAUDE_SYSTEM_PROMPT=You are a helpful assistant...

# System prompt for family group chat (optional — has sensible default)
# CLAUDE_FAMILY_SYSTEM_PROMPT=You are a friendly family helper...

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
