# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed in private chat
# Get your ID via @userinfobot
TELEGRAM_ALLOWED_USER_IDS=123456789

# ── Claude / Anthropic ────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# Default models per mode (can be switched at runtime via /model)
CLAUDE_PERSONAL_MODEL=claude-opus-4-6
CLAUDE_FAMILY_MODEL=claude-sonnet-4-5-20241022

# Max tokens per response
CLAUDE_MAX_TOKENS=4096

# How many messages to keep in history
CLAUDE_HISTORY_LIMIT=30

# Max tool_use loop iterations per request
CLAUDE_MAX_TOOL_TURNS=10

# System prompts (optional — have sensible defaults)
# CLAUDE_SYSTEM_PROMPT=...
# CLAUDE_FAMILY_SYSTEM_PROMPT=...

# ── Knowledge Base (MCP SSE on same VPS) ──────────────────────────────────────
# Local: http://127.0.0.1:8000/sse (no token needed)
# External: https://davlat-kb.duckdns.org/sse (needs token)
KB_URL=http://127.0.0.1:8000/sse
KB_TOKEN=

# ── Notion ────────────────────────────────────────────────────────────────────
# Internal integration token (https://www.notion.so/my-integrations)
NOTION_API_KEY=ntn_...
# Database ID for creating tasks (32-char hex from URL)
NOTION_TASKS_DATABASE_ID=

# ── Memory (SQLite) ──────────────────────────────────────────────────────────
MEMORY_DB_PATH=data/memory.db

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
